---
import { ArrowRight, Lock, ShieldCheck, Headset } from "lucide-astro";
---

<section class="py-12 md:py-24 bg-gradient-to-br from-primary to-[#2900ff] text-white relative overflow-hidden" id="registro">
    <div class="absolute inset-0 bg-black/20"></div>
    <div id="custom-alert" class="fixed top-10 left-1/2 -translate-x-1/2 z-[100] hidden">
        <div class="bg-white/20 backdrop-blur-xl border border-white/30 px-6 py-4 rounded-2xl shadow-2xl flex items-center gap-3 animate-bounce">
            <span class="text-2xl">⚠️</span>
            <p id="alert-message" class="font-bold text-sm md:text-base text-white tracking-wide"></p>
        </div>
    </div>

    <div class="max-w-4xl mx-auto px-6 relative z-10">
        <div class="bg-white/10 backdrop-blur-xl rounded-[2rem] p-6 md:p-12 border border-white/20 shadow-2xl">
            <form id="pioneros-form" class="space-y-4 md:space-y-6" onsubmit="return false;">
                <div class="grid md:grid-cols-2 gap-4 md:gap-6">
                    <div class="space-y-2">
                        <label class="font-bold text-xs uppercase text-white/80 px-2">Nombre Completo</label>
                        <input name="nombre" class="w-full px-5 py-3 bg-white/20 border-2 border-white/30 rounded-2xl text-white" placeholder="Ej. Maria Garcia" type="text" required />
                    </div>
                    <div class="space-y-2">
                        <label class="font-bold text-xs uppercase text-white/80 px-2">Correo Electrónico</label>
                        <input name="email" id="email" class="w-full px-5 py-3 bg-white/20 border-2 border-white/30 rounded-2xl text-white" placeholder="maria@tuempresa.com" type="email" required />
                    </div>
                </div>

                <div class="grid md:grid-cols-2 gap-4 md:gap-6">
                    <div class="space-y-2">
                        <label class="font-bold text-xs uppercase text-white px-2">Teléfono (Colombia)</label>
                        <input name="tel" id="tel" class="w-full px-5 py-3 bg-white/20 border-2 border-white/30 rounded-2xl text-white" placeholder="3155870958" type="tel" maxlength="10" required />
                    </div>
                    <div class="space-y-2">
                        <label class="font-bold text-xs uppercase text-white/80 px-2">Categoría</label>
                        <select name="categoria" class="w-full px-5 py-3 bg-white/20 border-2 border-white/30 rounded-2xl text-white appearance-none">
                            <option value="moda">Moda y Accesorios</option>
                            <option value="hogar">Hogar y Decoración</option>
                            <option value="belleza">Belleza y Salud</option>
                            <option value="tecnologia">Tecnología</option>
                        </select>
                    </div>
                </div>

                <input type="text" name="company" style="display:none" tabindex="-1" autocomplete="off" />

                <button id="submit-btn" class="w-full bg-[#FFD700] hover:bg-yellow-400 text-black font-black text-lg py-4 rounded-2xl shadow-xl flex items-center justify-center gap-2" type="submit">
                    🚀 REGISTRARME AHORA
                    <ArrowRight class="w-5 h-5" />
                </button>
            </form>
        </div>
    </div>
</section>

<script>
    (function() {
        const initForm = () => {
            console.log("🛠️ DEBUG: Script BeTogether inicializado en " + window.location.href);

            const form = document.getElementById('pioneros-form') as HTMLFormElement | null;
            const btn = document.getElementById('submit-btn') as HTMLButtonElement | null;
            const alertBox = document.getElementById('custom-alert') as HTMLDivElement | null;
            const alertMsg = document.getElementById('alert-message') as HTMLParagraphElement | null;

            if (!form || !btn) {
                console.error("❌ DEBUG: No se encontró el formulario o el botón en el DOM");
                return;
            }

            form.addEventListener('submit', async (e: Event) => {
                e.preventDefault();
                e.stopPropagation();
                
                console.log("🚀 DEBUG: Evento SUBMIT capturado correctamente");
                
                const formData = new FormData(form);
                const nombre = (formData.get("nombre") || "").toString();
                const email = (formData.get("email") || "").toString();

                console.log("📝 DEBUG: Datos listos para enviar:", { nombre, email });

                btn.disabled = true;
                const originalContent = btn.innerHTML;
                btn.innerHTML = "<span>⏳ PROCESANDO...</span>";

                try {
                    const apiUrl = `${window.location.origin}/api/register/`;
                    console.log("📡 DEBUG: Intentando Fetch a URL:", apiUrl);

                    const response = await fetch(apiUrl, {
                        method: 'POST',
                        body: formData
                    });

                    console.log("📡 DEBUG: Status de respuesta del servidor:", response.status);

                    if (response.ok) {
                        const data = await response.json();
                        console.log("✅ DEBUG: API respondió éxito:", data);
                        window.location.href = "/gracias/";
                    } else {
                        const errorText = await response.text();
                        console.error("❌ DEBUG: Error del servidor:", response.status, errorText);
                        
                        if (alertMsg && alertBox) {
                            alertMsg.innerText = "ERROR EN EL SERVIDOR (" + response.status + ")";
                            alertBox.classList.remove('hidden');
                        }
                        btn.disabled = false;
                        btn.innerHTML = originalContent;
                    }
                } catch (error) {
                    console.error("❌ DEBUG: Fallo crítico en la conexión:", error);
                    btn.disabled = false;
                    btn.innerHTML = originalContent;
                }
            });
        };

        window.addEventListener('load', initForm);
        document.addEventListener('astro:page-load', initForm);
    })();
</script>